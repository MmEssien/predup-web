# PredUp Frontend Environment Variables
# Copy this file to .env.local for local development

# ==========================================
# REQUIRED: API Configuration
# ==========================================

# Backend API URL (without trailing slash)
# For local development:
NEXT_PUBLIC_API_URL=http://localhost:8000

# For production (example):
# NEXT_PUBLIC_API_URL=https://api-predup.up.railway.app
# NEXT_PUBLIC_API_URL=https://your-backend-domain.com

# ==========================================
# OPTIONAL: App Configuration
# ==========================================

# App name displayed in UI
NEXT_PUBLIC_APP_NAME=PredUp

# Environment (development, staging, production)
NEXT_PUBLIC_APP_ENV=development

# ==========================================
# OPTIONAL: Feature Flags
# ==========================================

# Enable/disable features
# NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_BETTING=true

# ==========================================
# DO NOT COMMIT THESE TO VERSION CONTROL
# ==========================================

# .env.local is gitignored - use it for local overrides
# .env.production is used during Vercel deployment